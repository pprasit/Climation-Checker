<Window x:Class="ClimationChecker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClimationChecker.App"
        Title="DonutScope"
        Width="1580"
        Height="1030"
        Icon="Assets/app-icon.ico"
        MinWidth="1360"
        MinHeight="910"
        WindowStartupLocation="Manual"
        Background="#050505">
    <Window.Resources>
        <ScaleTransform x:Key="InvertHorizontalScrollBarTransform"
                        ScaleX="-1" />
        <ScaleTransform x:Key="InvertVerticalScrollBarTransform"
                        ScaleY="-1" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#080808" />
        <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#101010" />
        <SolidColorBrush x:Key="SurfaceFooterBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#303030" />
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#070707" />
        <SolidColorBrush x:Key="ControlBackgroundHoverBrush" Color="#141414" />
        <SolidColorBrush x:Key="ControlBackgroundPressedBrush" Color="#020202" />
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#343434" />
        <SolidColorBrush x:Key="ControlBorderHoverBrush" Color="#565656" />
        <SolidColorBrush x:Key="ControlTextBrush" Color="#E4E4E4" />
        <SolidColorBrush x:Key="ControlMutedTextBrush" Color="#9A9A9A" />
        <SolidColorBrush x:Key="ControlAccentBrush" Color="#C7C7C7" />
        <SolidColorBrush x:Key="ControlAccentSoftBrush" Color="#242424" />
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}" />
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource ControlAccentBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource ControlAccentSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource ControlAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource ControlBorderHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}" />
            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Path x:Name="Arrow"
                                                      Width="8"
                                                      Height="5"
                                                      Margin="0,0,12,0"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="{StaticResource ControlMutedTextBrush}" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ControlBackgroundHoverBrush}" />
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource ControlBorderHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource ControlAccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="10,0,30,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              IsHitTestVisible="False" />
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource ControlBorderHoverBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <ScrollViewer Margin="2"
                                                  CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Background" Value="#111111" />
                                <Setter Property="Foreground" Value="#C8C8C8" />
                                <Setter Property="BorderBrush" Value="#303030" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#252525" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#303030" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box"
                                    Width="15"
                                    Height="15"
                                    Margin="0,0,7,0"
                                    VerticalAlignment="Center"
                                    CornerRadius="2"
                                    Background="{StaticResource ControlBackgroundBrush}"
                                    BorderBrush="{StaticResource ControlBorderBrush}"
                                    BorderThickness="1">
                                <Path x:Name="Check"
                                      Data="M 3 7 L 6 10 L 12 4"
                                      Stroke="{StaticResource ControlAccentBrush}"
                                      StrokeThickness="2"
                                      StrokeEndLineCap="Round"
                                      StrokeStartLineCap="Round"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource ControlAccentSoftBrush}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource ControlAccentBrush}" />
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource ControlBorderHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource ControlAccentBrush}" />
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#5E5E5E" />
            <Setter Property="Background" Value="#0B1117" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <Grid x:Name="PART_Track">
                                <Rectangle x:Name="PART_Indicator"
                                           HorizontalAlignment="Left"
                                           Fill="{TemplateBinding Foreground}"
                                           RadiusX="3"
                                           RadiusY="3" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource ControlTextBrush}" />
            <Setter Property="Background" Value="#202020" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#2A2A2A" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource ControlBorderHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#111111" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#242424" />
            <Setter Property="BorderBrush" Value="#464646" />
        </Style>
        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#171717" />
        </Style>
        <Style x:Key="SubtleCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#B9C6D1" />
            <Setter Property="Background" Value="#151515" />
            <Setter Property="BorderBrush" Value="#363636" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <DataTemplate DataType="{x:Type local:ExposureHistoryItem}">
            <StackPanel Width="128">
                <Border Height="96"
                        CornerRadius="4"
                        Background="#0C1116"
                        BorderBrush="#2C3B48"
                        BorderThickness="1">
                    <Image Source="{Binding Snapshot}"
                           Stretch="Uniform" />
                </Border>
                <TextBlock Margin="0,6,0,0"
                           Foreground="#D6E0E7"
                           FontSize="11"
                           TextAlignment="Center"
                           Text="{Binding Caption}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1.4*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,16,0"
                Padding="16"
                CornerRadius="5"
                Background="{StaticResource SurfaceRaisedBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel LastChildFill="False">
                    <TextBlock x:Name="FrameInfoTextBlock"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource ControlMutedTextBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="Resolution -- x -- px | -- bit" />
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal">
                        <CheckBox x:Name="UseImageFolderCheckBox"
                                  Margin="0,0,18,0"
                                  Foreground="#D6E0E7"
                                  FontSize="14"
                                  FontWeight="SemiBold"
                                  Content="Run in simulation mode" />
                        <CheckBox x:Name="ShowOverlayCheckBox"
                                  IsChecked="True"
                                  Checked="ShowOverlayCheckBox_OnChanged"
                                  Unchecked="ShowOverlayCheckBox_OnChanged"
                                  Foreground="#D6E0E7"
                                  FontSize="14"
                                  FontWeight="SemiBold"
                                  Content="Show Ring Overlay" />
                        <CheckBox x:Name="ShowOnlyDonutRingCheckBox"
                                  Margin="18,0,0,0"
                                  Checked="ShowOnlyDonutRingCheckBox_OnChanged"
                                  Unchecked="ShowOnlyDonutRingCheckBox_OnChanged"
                                  Foreground="#D6E0E7"
                                  FontSize="14"
                                  FontWeight="SemiBold"
                                  Content="Show Only Donut Ring" />
                    </StackPanel>
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="0,16,0,0"
                        Padding="12"
                        CornerRadius="5"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="ReferencePreviewPanel"
                                Grid.Row="0"
                                Grid.Column="0"
                                Width="350"
                                Margin="0,0,12,0"
                                Padding="10"
                                Visibility="Collapsed"
                                CornerRadius="5"
                                Background="#030303"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Selected Frame"
                                               VerticalAlignment="Center"
                                               Foreground="#D6E0E7"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                    <Button x:Name="CloseReferencePreviewButton"
                                            Grid.Column="1"
                                            Style="{StaticResource SubtleCloseButtonStyle}"
                                            HorizontalAlignment="Right"
                                            Click="CloseReferencePreviewButton_OnClick"
                                            Content="Close" />
                                </Grid>
                                <Image x:Name="ReferencePreviewImage"
                                       Grid.Row="1"
                                       Margin="0,10,0,0"
                                       Stretch="Uniform" />
                            </Grid>
                        </Border>

                        <Border x:Name="LivePreviewPanel"
                                Grid.Row="0"
                                Grid.Column="1"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="#263442"
                                BorderThickness="0"
                                CornerRadius="5">
                            <Grid Background="#030303">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="16" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                </Grid.ColumnDefinitions>
                                <ScrollViewer x:Name="PreviewScrollViewer"
                                              Grid.Row="0"
                                              Grid.Column="0"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"
                                              Background="#030303"
                                              ScrollChanged="PreviewScrollViewer_OnScrollChanged"
                                              SizeChanged="PreviewScrollViewer_OnSizeChanged"
                                              PreviewMouseLeftButtonDown="PreviewScrollViewer_OnPreviewMouseLeftButtonDown"
                                              PreviewMouseLeftButtonUp="PreviewScrollViewer_OnPreviewMouseLeftButtonUp"
                                              PreviewMouseMove="PreviewScrollViewer_OnPreviewMouseMove"
                                              PreviewMouseWheel="PreviewScrollViewer_OnPreviewMouseWheel"
                                              MouseLeave="PreviewScrollViewer_OnMouseLeave">
                                    <Grid x:Name="PreviewImageHost"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top">
                                        <Image x:Name="PreviewImage"
                                               Stretch="Fill"
                                               SizeChanged="PreviewImage_OnSizeChanged" />
                                        <Canvas x:Name="OverlayCanvas"
                                                IsHitTestVisible="False" />
                                    </Grid>
                                </ScrollViewer>
                                <ScrollBar x:Name="PreviewVerticalScrollBar"
                                           Grid.Row="0"
                                           Grid.Column="1"
                                           Orientation="Vertical"
                                           LayoutTransform="{StaticResource InvertVerticalScrollBarTransform}"
                                           ValueChanged="PreviewVerticalScrollBar_OnValueChanged" />
                                <ScrollBar x:Name="PreviewHorizontalScrollBar"
                                           Grid.Row="1"
                                           Grid.Column="0"
                                           Orientation="Horizontal"
                                           LayoutTransform="{StaticResource InvertHorizontalScrollBarTransform}"
                                           ValueChanged="PreviewHorizontalScrollBar_OnValueChanged" />
                            </Grid>
                        </Border>

                        <DockPanel Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   Margin="6,12,6,0"
                                   LastChildFill="False">
                            <CheckBox x:Name="ShowGraphCheckBox"
                                      DockPanel.Dock="Right"
                                      Margin="18,0,0,0"
                                      Foreground="#D6E0E7"
                                      FontSize="13"
                                      FontWeight="SemiBold"
                                      Content="Show Graph"
                                      Checked="ShowGraphCheckBox_OnChanged"
                                      Unchecked="ShowGraphCheckBox_OnChanged" />
                            <TextBlock Text="Zoom Percent"
                                       VerticalAlignment="Center"
                                       Foreground="#D6E0E7"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <ComboBox x:Name="ZoomComboBox"
                                      Width="110"
                                      Height="32"
                                      Margin="12,0,0,0"
                                      SelectedIndex="0"
                                      SelectionChanged="ZoomComboBox_OnSelectionChanged">
                                <ComboBoxItem Content="Fit" Tag="Fit" />
                                <ComboBoxItem Content="25%" Tag="25" />
                                <ComboBoxItem Content="50%" Tag="50" />
                                <ComboBoxItem Content="75%" Tag="75" />
                                <ComboBoxItem Content="100%" Tag="100" />
                                <ComboBoxItem Content="150%" Tag="150" />
                                <ComboBoxItem Content="200%" Tag="200" />
                                <ComboBoxItem Content="300%" Tag="300" />
                                <ComboBoxItem Content="400%" Tag="400" />
                            </ComboBox>
                            <TextBlock Margin="18,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource ControlMutedTextBrush}"
                                       FontSize="13"
                                       Text="Drag the image to pan, or use the scrollbars." />
                        </DockPanel>

                        <Border Grid.Row="2"
                                Grid.ColumnSpan="2"
                                Margin="6,12,6,0"
                                Padding="8"
                                MinHeight="126"
                                CornerRadius="5"
                                Background="#0A0A0A"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1">
                            <ListBox x:Name="ThumbnailListBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ScrollViewer.CanContentScroll="False"
                                     SelectionChanged="ThumbnailListBox_OnSelectionChanged">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="0,0,10,0" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Padding="18"
                CornerRadius="5"
                Background="{StaticResource SurfaceRaisedBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Session"
                                   Foreground="#F3F6F8"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="CcdConnectionStatusTextBlock"
                                   Grid.Row="1"
                                   Margin="0,6,0,0"
                                   Text="CCD FLI Connected"
                                   Foreground="#9AA7B2"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Visibility="Collapsed" />
                    </Grid>

                    <TextBlock x:Name="CurrentFileTextBlock"
                               Visibility="Collapsed" />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Margin="0,0,0,10">
                            <ComboBox x:Name="ExposureModeComboBox"
                                      Width="220"
                                      Margin="0,0,0,10"
                                      SelectedIndex="0"
                                      SelectionChanged="ExposureModeComboBox_OnSelectionChanged">
                                <ComboBoxItem Content="Single Expose" Tag="SingleExpose" />
                                <ComboBoxItem Content="Continue Expose" Tag="ContinuousExpose" />
                                <ComboBoxItem Content="Continue Expose with ROI" Tag="ContinuousExposeWithRoi" />
                            </ComboBox>
                            <Button x:Name="ExposeButton"
                                    Width="220"
                                    Height="40"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Click="ExposeButton_OnClick"
                                    Content="Expose" />
                        </StackPanel>
                        <Grid Grid.Column="2"
                              Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SaveFolderTextBox"
                                     Grid.Row="0"
                                     Grid.Column="0"
                                     Margin="0,0,10,0" />
                            <Button x:Name="BrowseSaveFolderButton"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Width="92"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Click="BrowseSaveFolderButton_OnClick"
                                    Content="Browse" />
                            <CheckBox x:Name="AutoSaveFitsCheckBox"
                                      Grid.Row="1"
                                      Grid.ColumnSpan="2"
                                      Margin="0,10,0,0"
                                      Foreground="#D6E0E7"
                                      FontSize="13"
                                      FontWeight="SemiBold"
                                      Content="Auto Save FITS after exposure" />
                        </Grid>
                    </Grid>

                    <Border Margin="0,8,0,0"
                            Padding="14"
                            CornerRadius="5"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1">
                        <Expander IsExpanded="True"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <Expander.Header>
                                <TextBlock Text="CCD Control"
                                           Foreground="#F3F6F8"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                            </Expander.Header>
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="0">
                                    <TextBlock Text="Exposure Time (seconds)"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="ExposureSecondsTextBox"
                                             Margin="0,6,0,0"
                                             Text="1.0" />
                                </StackPanel>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="2">
                                    <TextBlock Text="Binning"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <ComboBox x:Name="BinningComboBox"
                                              Margin="0,6,0,0"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="1 x 1" Tag="1" />
                                        <ComboBoxItem Content="2 x 2" Tag="2" />
                                        <ComboBoxItem Content="3 x 3" Tag="3" />
                                        <ComboBoxItem Content="4 x 4" Tag="4" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="2"
                                            VerticalAlignment="Center">
                                    <CheckBox x:Name="CoolerEnabledCheckBox"
                                              Foreground="#D6E0E7"
                                              FontWeight="SemiBold"
                                              Content="Cooler On"
                                              Checked="CoolerEnabledCheckBox_OnChanged"
                                              Unchecked="CoolerEnabledCheckBox_OnChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="4">
                                    <TextBlock Text="Sensor Temp (°C)"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="SensorTemperatureTextBlock"
                                               Margin="0,10,0,0"
                                               Foreground="#9FD1FF"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="--.- °C" />
                                </StackPanel>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="4">
                                    <TextBlock Text="Cooler Set Point (°C)"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="CoolerSetPointTextBox"
                                             Margin="0,6,0,0"
                                             Text="10"
                                             LostFocus="CoolerSetPointTextBox_OnLostFocus" />
                                </StackPanel>
                            </Grid>
                        </Expander>
                    </Border>

                    <Border Margin="0,16,0,0"
                            Padding="14"
                            CornerRadius="5"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1">
                        <Expander IsExpanded="True"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <Expander.Header>
                                <TextBlock Text="Stretch"
                                           Foreground="#F3F6F8"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                            </Expander.Header>
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="0">
                                    <TextBlock Text="Stretch Profile"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <ComboBox x:Name="StretchProfileComboBox"
                                              Margin="0,6,0,0"
                                              SelectionChanged="StretchProfileComboBox_OnSelectionChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="2">
                                    <TextBlock Text="Stretch Low Percentile"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="66" />
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="LowStretchSlider"
                                                Grid.Column="0"
                                                Minimum="0"
                                                Maximum="20"
                                                Value="1"
                                                TickFrequency="0.5"
                                                IsSnapToTickEnabled="False"
                                                ValueChanged="StretchSlider_OnValueChanged" />
                                        <TextBlock x:Name="LowStretchValueTextBlock"
                                                   Grid.Column="1"
                                                   Width="56"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#9FD1FF"
                                                   FontSize="14"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="0">
                                    <TextBlock Text="Stretch High Percentile"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="66" />
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="HighStretchSlider"
                                                Grid.Column="0"
                                                Minimum="90"
                                                Maximum="100"
                                                Value="99.8"
                                                TickFrequency="0.1"
                                                IsSnapToTickEnabled="False"
                                                ValueChanged="StretchSlider_OnValueChanged" />
                                        <TextBlock x:Name="HighStretchValueTextBlock"
                                                   Grid.Column="1"
                                                   Width="56"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#9FD1FF"
                                                   FontSize="14"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </StackPanel>

                                <Border Grid.Row="2"
                                        Grid.Column="2"
                                        Padding="12,10"
                                        CornerRadius="5"
                                        Background="#050505"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock Foreground="#89A1B4"
                                               FontSize="12"
                                               TextWrapping="Wrap">
                                        Stretch changes affect only the preview. Analysis values update after the next exposure.
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Expander>
                    </Border>

                    <Border Margin="0,16,0,0"
                            Padding="14"
                            CornerRadius="5"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Analysis"
                                           Foreground="#F3F6F8"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="AnalysisScoreTextBlock"
                                           DockPanel.Dock="Right"
                                           Margin="12,2,0,0"
                                           Text="Score --.--%"
                                           Foreground="#FFB347"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                            </DockPanel>
                            <TextBlock x:Name="StatusTextBlock"
                                       Margin="0,10,0,0"
                                       Foreground="#FFD69A"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Text="Waiting for simulation..." />
                            <TextBlock x:Name="MetricsTextBlock"
                                       Margin="0,14,0,0"
                                       Foreground="#D6E0E7"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,16,0,0"
                Padding="14,10"
                CornerRadius="5"
                Background="{StaticResource SurfaceRaisedBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="WorkflowStatusTextBlock"
                               Text="Ready."
                               Foreground="#EAF3FA"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="WorkflowDetailTextBlock"
                               Margin="0,4,0,0"
                               Text="The viewer is idle."
                               Foreground="#8FA6B9"
                               FontSize="12" />
                </StackPanel>

                <Grid Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="WorkflowProgressBar"
                                 Height="16"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 VerticalAlignment="Center" />
                    <TextBlock x:Name="WorkflowProgressTextBlock"
                               Grid.Column="1"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#9FD1FF"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="0%" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
