<Window x:Class="ClimationChecker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Climation Checker"
        Width="1580"
        Height="880"
        MinWidth="1360"
        MinHeight="760"
        Background="#0E141A">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1.4*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,16,0"
                Padding="16"
                CornerRadius="5"
                Background="#162029"
                BorderBrush="#2C3B48"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel LastChildFill="False">
                    <TextBlock x:Name="ViewerTitleTextBlock"
                               Text="Exposure Viewer"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#F3F6F8" />
                    <CheckBox x:Name="ShowOverlayCheckBox"
                              DockPanel.Dock="Right"
                              Margin="18,8,0,0"
                              IsChecked="True"
                              Checked="ShowOverlayCheckBox_OnChanged"
                              Unchecked="ShowOverlayCheckBox_OnChanged"
                              Foreground="#D6E0E7"
                              FontSize="14"
                              FontWeight="SemiBold"
                              Content="Show Ring Overlay" />
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="0,16,0,0"
                        Padding="12"
                        CornerRadius="5"
                        Background="#0C1116"
                        BorderBrush="#263442"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Image x:Name="PreviewImage"
                                   Stretch="Uniform"
                                   SizeChanged="PreviewImage_OnSizeChanged" />
                            <Canvas x:Name="OverlayCanvas"
                                    IsHitTestVisible="False" />
                        </Grid>

                        <TextBlock Grid.Row="1"
                                   Margin="6,12,6,0"
                                   Foreground="#89A1B4"
                                   FontSize="13"
                                   TextWrapping="Wrap">
                            Cyan = outer ring, Magenta = inner ring. The preview is generated by the Python analyzer with stretch applied from the sliders on the right.
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Padding="18"
                CornerRadius="5"
                Background="#162029"
                BorderBrush="#2C3B48"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Session"
                               Foreground="#F3F6F8"
                               FontSize="24"
                               FontWeight="SemiBold" />

                    <TextBlock x:Name="CurrentFileTextBlock"
                               Visibility="Collapsed" />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="ExposeButton"
                                Grid.Column="0"
                                Width="150"
                                Height="40"
                                Margin="0,0,0,10"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Click="ExposeButton_OnClick"
                                Content="Expose" />
                        <Grid Grid.Column="2"
                              Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SaveFolderTextBox"
                                     Grid.Row="0"
                                     Grid.Column="0"
                                     Margin="0,0,10,0" />
                            <Button x:Name="BrowseSaveFolderButton"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Width="92"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Click="BrowseSaveFolderButton_OnClick"
                                    Content="Browse" />
                            <CheckBox x:Name="AutoSaveFitsCheckBox"
                                      Grid.Row="1"
                                      Grid.ColumnSpan="2"
                                      Margin="0,10,0,0"
                                      Foreground="#D6E0E7"
                                      FontSize="13"
                                      FontWeight="SemiBold"
                                      Content="Auto Save FITS after exposure" />
                        </Grid>
                    </Grid>

                    <Border Margin="0,8,0,0"
                            Padding="14"
                            CornerRadius="5"
                            Background="#101820"
                            BorderBrush="#263442"
                            BorderThickness="1">
                        <Expander IsExpanded="True"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <Expander.Header>
                                <TextBlock Text="CCD Control"
                                           Foreground="#F3F6F8"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                            </Expander.Header>
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="0">
                                    <TextBlock Text="Exposure Time (seconds)"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="ExposureSecondsTextBox"
                                             Margin="0,6,0,0"
                                             Text="1.0" />
                                </StackPanel>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="2">
                                    <TextBlock Text="Binning"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <ComboBox x:Name="BinningComboBox"
                                              Margin="0,6,0,0"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="1 x 1" Tag="1" />
                                        <ComboBoxItem Content="2 x 2" Tag="2" />
                                        <ComboBoxItem Content="3 x 3" Tag="3" />
                                        <ComboBoxItem Content="4 x 4" Tag="4" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="0"
                                            VerticalAlignment="Center">
                                    <CheckBox x:Name="CoolerEnabledCheckBox"
                                              Foreground="#D6E0E7"
                                              FontWeight="SemiBold"
                                              Content="Cooler On"
                                              Checked="CoolerEnabledCheckBox_OnChanged"
                                              Unchecked="CoolerEnabledCheckBox_OnChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="2">
                                    <TextBlock Text="Cooler Set Point (°C)"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="CoolerSetPointTextBox"
                                             Margin="0,6,0,0"
                                             Text="-10"
                                             IsEnabled="False" />
                                </StackPanel>
                            </Grid>
                        </Expander>
                    </Border>

                    <Border Margin="0,16,0,0"
                            Padding="14"
                            CornerRadius="5"
                            Background="#101820"
                            BorderBrush="#263442"
                            BorderThickness="1">
                        <Expander IsExpanded="True"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <Expander.Header>
                                <TextBlock Text="Stretch"
                                           Foreground="#F3F6F8"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                            </Expander.Header>
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="0">
                                    <TextBlock Text="Stretch Profile"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <ComboBox x:Name="StretchProfileComboBox"
                                              Margin="0,6,0,0"
                                              SelectionChanged="StretchProfileComboBox_OnSelectionChanged" />
                                </StackPanel>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="2">
                                    <TextBlock Text="Stretch Low Percentile"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="66" />
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="LowStretchSlider"
                                                Grid.Column="0"
                                                Minimum="0"
                                                Maximum="20"
                                                Value="1"
                                                TickFrequency="0.5"
                                                IsSnapToTickEnabled="False"
                                                ValueChanged="StretchSlider_OnValueChanged" />
                                        <TextBlock x:Name="LowStretchValueTextBlock"
                                                   Grid.Column="1"
                                                   Width="56"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#9FD1FF"
                                                   FontSize="14"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="0">
                                    <TextBlock Text="Stretch High Percentile"
                                               Foreground="#D6E0E7"
                                               FontWeight="SemiBold" />
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="66" />
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="HighStretchSlider"
                                                Grid.Column="0"
                                                Minimum="90"
                                                Maximum="100"
                                                Value="99.8"
                                                TickFrequency="0.1"
                                                IsSnapToTickEnabled="False"
                                                ValueChanged="StretchSlider_OnValueChanged" />
                                        <TextBlock x:Name="HighStretchValueTextBlock"
                                                   Grid.Column="1"
                                                   Width="56"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#9FD1FF"
                                                   FontSize="14"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </StackPanel>

                                <Border Grid.Row="2"
                                        Grid.Column="2"
                                        Padding="12,10"
                                        CornerRadius="5"
                                        Background="#0D141B"
                                        BorderBrush="#223240"
                                        BorderThickness="1">
                                    <TextBlock Foreground="#89A1B4"
                                               FontSize="12"
                                               TextWrapping="Wrap">
                                        Stretch changes affect only the preview. Analysis values update after the next exposure.
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Expander>
                    </Border>

                    <Border Margin="0,16,0,0"
                            Padding="14"
                            CornerRadius="5"
                            Background="#101820"
                            BorderBrush="#263442"
                            BorderThickness="1">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Analysis"
                                           Foreground="#F3F6F8"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="AnalysisScoreTextBlock"
                                           DockPanel.Dock="Right"
                                           Margin="12,2,0,0"
                                           Text="Score --.--%"
                                           Foreground="#FFB347"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                            </DockPanel>
                            <TextBlock x:Name="StatusTextBlock"
                                       Margin="0,10,0,0"
                                       Foreground="#FFD69A"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Text="Waiting for simulation..." />
                            <TextBlock x:Name="MetricsTextBlock"
                                       Margin="0,14,0,0"
                                       Foreground="#D6E0E7"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,16,0,0"
                Padding="14,10"
                CornerRadius="5"
                Background="#162029"
                BorderBrush="#2C3B48"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="WorkflowStatusTextBlock"
                               Text="Ready."
                               Foreground="#EAF3FA"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="WorkflowDetailTextBlock"
                               Margin="0,4,0,0"
                               Text="The viewer is idle."
                               Foreground="#8FA6B9"
                               FontSize="12" />
                </StackPanel>

                <Grid Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="WorkflowProgressBar"
                                 Height="16"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 VerticalAlignment="Center" />
                    <TextBlock x:Name="WorkflowProgressTextBlock"
                               Grid.Column="1"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#9FD1FF"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="0%" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
